<!DOCTYPE html>
<html>
<head>
    <title>Simple Calculator</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            margin-top: 50px;
        }

        input {
            width: 200px;
            padding: 8px;
            margin: 5px;
        }

        button {
            width: 50px;
            height: 40px;
            margin: 3px;
            font-size: 18px;
        }

        #result {
            font-size: 24px;
            color: blue;
            margin-top: 20px;
        }
    </style>
</head>
<body>

    <h2>Simple Calculator</h2>

    <!-- Input boxes -->
    <input type="number" id="num1" placeholder="First Number"><br>
    <input type="number" id="num2" placeholder="Second Number"><br><br>

    <!-- Operation Buttons -->
    <button onclick="calculate('+')">+</button>
    <button onclick="calculate('-')">-</button>
    <button onclick="calculate('*')">*</button>
    <button onclick="calculate('/')">/</button>

    <!-- Result -->
    <p id="result">Result will appear here.</p>

    <script>
        function calculate(operator) {
            var a = parseFloat(document.getElementById("num1").value);
            var b = parseFloat(document.getElementById("num2").value);
            var result;

            // Check if inputs are valid
            if (isNaN(a) || isNaN(b)) {
                document.getElementById("result").innerHTML =
                    "Please enter both numbers.";
                return;
            }

            // Perform operation using switch-case
            switch (operator) {
                case '+':
                    result = a + b;
                    break;

                case '-':
                    result = a - b;
                    break;

                case '*':
                    result = a * b;
                    break;

                case '/':
                    if (b == 0) {
                        document.getElementById("result").innerHTML =
                            "Cannot divide by zero.";
                        return;
                    }
                    result = a / b;
                    break;
            }

            // Display result
            document.getElementById("result").innerHTML =
                "Result = " + result;
        }
    </script>

</body>
</html>
