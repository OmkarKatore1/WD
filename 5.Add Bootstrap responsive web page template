<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Responsive Web Page</title>

    <!-- Bootstrap CSS CDN -->
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">My Website</a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Heading -->
    <div class="container mt-4">
        <h1 class="text-center mb-4">Bootstrap Grid System Example</h1>

        <!-- Grid with Cards -->
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card shadow">
                    <img src="https://via.placeholder.com/300x200"
                         class="card-img-top" alt="Card Image">
                    <div class="card-body">
                        <h5 class="card-title">Web Design</h5>
                        <p class="card-text">
                            Learn HTML, CSS, JavaScript, and Bootstrap.
                        </p>
                        <a href="#" class="btn btn-primary">Read More</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow">
                    <img src="https://via.placeholder.com/300x200"
                         class="card-img-top" alt="Card Image">
                    <div class="card-body">
                        <h5 class="card-title">Programming</h5>
                        <p class="card-text">
                            Practice C, C++, Java, and Python.
                        </p>
                        <a href="#" class="btn btn-success">Explore</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow">
                    <img src="https://via.placeholder.com/300x200"
                         class="card-img-top" alt="Card Image">
                    <div class="card-body">
                        <h5 class="card-title">Projects</h5>
                        <p class="card-text">
                            Build real-world mini and major projects.
                        </p>
                        <a href="#" class="btn btn-danger">View Projects</a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Bootstrap JS CDN -->
    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

</body>
</html>
