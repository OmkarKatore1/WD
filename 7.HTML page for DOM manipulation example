<!DOCTYPE html>
<html>
<head>
    <title>DOM Manipulation Example</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            margin-top: 50px;
        }

        #result {
            font-size: 24px;
            color: blue;
            margin-top: 20px;
        }

        button {
            padding: 8px 15px;
            margin-top: 10px;
        }
    </style>
</head>
<body>

    <h2>JavaScript DOM Manipulation</h2>

    <p>Enter your name and click the button.</p>

    <input type="text" id="name" placeholder="Enter your name">
    <br><br>

    <button onclick="showMessage()">Display Message</button>
    <button onclick="changeColor()">Change Color</button>
    <button onclick="clearMessage()">Clear</button>

    <p id="result">Your message will appear here.</p>

    <script>
        // Display message
        function showMessage() {
            var username = document.getElementById("name").value;

            if (username == "") {
                document.getElementById("result").innerHTML =
                    "Please enter your name.";
            } else {
                document.getElementById("result").innerHTML =
                    "Hello, " + username + "! Welcome to Web Development.";
            }
        }

        // Change text color
        function changeColor() {
            document.getElementById("result").style.color = "red";
        }

        // Clear input and message
        function clearMessage() {
            document.getElementById("name").value = "";
            document.getElementById("result").innerHTML =
                "Your message will appear here.";
            document.getElementById("result").style.color = "blue";
        }
    </script>

</body>
</html>
